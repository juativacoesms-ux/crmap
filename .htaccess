RewriteEngine On

# Redirecionar para o novo domínio crmapoficial.org.br
RewriteCond %{HTTP_HOST} ^(www\.)?cdrmap\.com\.br$ [NC]
RewriteRule ^(.*)$ https://crmapoficial.org.br/$1 [R=301,L]

# Canonical host sem www
RewriteCond %{HTTP_HOST} ^www\.crmapoficial\.org\.br$ [NC]
RewriteRule ^(.*)$ https://crmapoficial.org.br/$1 [R=301,L]

# Garantir HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Canonicalizar URLs alternativas para as canônicas
RewriteRule ^index\.html$ / [R=301,L]
RewriteRule ^index_backup\.html$ / [R=301,L]
RewriteRule ^(acoes|produtos|terreno)/index\.html$ /$1/ [R=301,L]
RewriteRule ^(acoes|produtos|terreno)$ /$1/ [R=301,L]
RewriteRule ^carteirinha/?$ /carteirinha.html [R=301,L]
RewriteRule ^crmap2/?$ / [R=301,L]
